FROM docker.m.daocloud.io/library/debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    clang llvm lld libelf-dev libbpf-dev \
    libssl-dev pkg-config wget ca-certificates curl gcc && \
    rm -rf /var/lib/apt/lists/*

RUN wget -qO- https://sh.rustup.rs | sh /dev/stdin -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

# Cilium headers not needed — BPF object is pre-built on the host.

COPY Cargo.toml Cargo.lock ./
COPY src/ ./src/
COPY probes/ ./probes/

RUN cargo build --release

FROM docker.m.daocloud.io/library/debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    libelf1 libssl3 ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=0 /app/target/release/pg-collector /app/pg-collector
COPY --from=0 /app/probes/probe.bpf.o /app/probes/probe.bpf.o

CMD ["/app/pg-collector"]
