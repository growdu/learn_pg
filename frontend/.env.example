# Vite-injected runtime configuration. Copy to .env.local and edit.

# Base URL the frontend uses when calling /api/* and /ws.
# Empty string (default) means same-origin: the frontend will call
# /api/... on whatever host served the bundle, which is what you
# want when nginx proxies /api to the Go backend.
#
# Set this when the frontend is served from a different origin
# than the backend, e.g. developing the frontend against a remote
# backend on another machine.
# VITE_API_BASE_URL=http://localhost:3010
