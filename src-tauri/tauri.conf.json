{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PG Visualizer",
  "version": "0.1.0",
  "identifier": "com.learnpg.visualizer",
  "build": {
    "devtools": true,
    "beforeDevCommand": "cd frontend && npm install && npm run dev",
    "beforeBuildCommand": "cd frontend && npm install && npm run build",
    "devUrl": "http://localhost:80",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "PG Kernel Visualizer",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
