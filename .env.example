# PostgreSQL Connection
PG_HOST=postgres
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=postgres

# Backend Service
API_PORT=3000
WS_PORT=8080

# eBPF Collector
COLLECTOR_WS_URL=ws://collector:8090
ENABLE_EBPF=true

# Frontend
FRONTEND_PORT=5173

# PG Data Directory (for collector)
PG_DATA_DIR=/var/lib/postgresql/data

# Logging
LOG_LEVEL=info