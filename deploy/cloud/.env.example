# Cloud Server Environment Configuration
# Copy this file to .env and modify values as needed

# ============== Common Configuration ==============
APP_ENV=cloud
APP_HOST=0.0.0.0
APP_EXTERNAL_HOST=your-domain.com

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=pgv
COMPOSE_NETWORK=pgv-net
COMPOSE_NETWORK_EXTERNAL=false

# ============== PostgreSQL Configuration ==============
# For cloud, typically use cloud provider's RDS
POSTGRES_HOST=your-rds-endpoint.rds.amazon.com
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=postgres
POSTGRES_HOST_AUTH_METHOD=md5

# ============== Backend Configuration ==============
BACKEND_HOST=backend
BACKEND_API_PORT=3000
BACKEND_WS_PORT=8080

# ============== Frontend Configuration ==============
FRONTEND_HOST=frontend
FRONTEND_PORT=80

# ============== Collector Configuration ==============
COLLECTOR_HOST=collector
COLLECTOR_PORT=8090
USE_EBPF=false

# ============== Paths ==============
PG_DATA_DIR=/var/lib/postgresql/data
PG_DATA_VOLUME=pg_data