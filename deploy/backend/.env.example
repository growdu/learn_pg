# Backend Module Environment Configuration
# Copy this file to .env and modify values as needed

# Common Configuration (should match postgres module)
COMPOSE_PROJECT_NAME=pgv
COMPOSE_NETWORK=pgv-net
COMPOSE_NETWORK_EXTERNAL=false

# PostgreSQL Configuration (should match postgres module)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Frontend Configuration (should match frontend module)
FRONTEND_HOST=frontend
FRONTEND_PORT=80

# Collector Configuration (should match collector module)
COLLECTOR_HOST=collector
COLLECTOR_PORT=8090

# Backend Configuration
BACKEND_API_PORT=3000
BACKEND_WS_PORT=8080
BACKEND_BUILD_CONTEXT=../../backend
BACKEND_DOCKERFILE=Dockerfile

# External Configuration
APP_ENV=development
APP_EXTERNAL_HOST=localhost

# Data Directory
PG_DATA_DIR=/var/lib/postgresql/data