# Frontend Module Environment Configuration
# Copy this file to .env and modify values as needed

# Common Configuration (should match other modules)
COMPOSE_PROJECT_NAME=pgv
COMPOSE_NETWORK=pgv-net
COMPOSE_NETWORK_EXTERNAL=false

# Backend Configuration (should match backend module)
BACKEND_HOST=backend
BACKEND_API_PORT=3000
BACKEND_WS_PORT=8080

# Frontend Configuration
FRONTEND_PORT=80
FRONTEND_BUILD_CONTEXT=../../frontend
FRONTEND_DOCKERFILE=Dockerfile