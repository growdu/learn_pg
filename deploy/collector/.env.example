# Collector Module Environment Configuration
# Copy this file to .env and modify values as needed

# Common Configuration (should match other modules)
COMPOSE_PROJECT_NAME=pgv
COMPOSE_NETWORK=pgv-net
COMPOSE_NETWORK_EXTERNAL=false

# PostgreSQL Configuration (should match postgres module)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
PG_DATA_DIR=/var/lib/postgresql/data
PG_DATA_VOLUME=pg_data

# Backend Configuration (should match backend module)
BACKEND_HOST=backend
BACKEND_WS_PORT=8080

# Collector Configuration
COLLECTOR_PORT=8090
COLLECTOR_BUILD_CONTEXT=../../collector
COLLECTOR_DOCKERFILE=Dockerfile

# Feature flags
USE_EBPF=false