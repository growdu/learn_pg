# Unified Environment Configuration
# Copy this file to .env and modify values as needed for local/docker deployment

# ============== Common Configuration ==============
APP_ENV=local
APP_HOST=0.0.0.0
APP_EXTERNAL_HOST=localhost

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=pgv
COMPOSE_NETWORK=pgv-net
COMPOSE_NETWORK_EXTERNAL=false

# ============== PostgreSQL Configuration ==============
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST_AUTH_METHOD=trust
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=100

# ============== Backend Configuration ==============
BACKEND_HOST=backend
BACKEND_API_PORT=3000
BACKEND_WS_PORT=8080
BACKEND_BUILD_CONTEXT=../../backend
BACKEND_DOCKERFILE=Dockerfile

# ============== Frontend Configuration ==============
FRONTEND_HOST=frontend
FRONTEND_PORT=80
FRONTEND_BUILD_CONTEXT=../../frontend
FRONTEND_DOCKERFILE=Dockerfile

# ============== Collector Configuration ==============
COLLECTOR_HOST=collector
COLLECTOR_PORT=8090
COLLECTOR_BUILD_CONTEXT=../../collector
COLLECTOR_DOCKERFILE=Dockerfile
USE_EBPF=false

# ============== Paths ==============
PG_DATA_DIR=/var/lib/postgresql/data
PG_DATA_VOLUME=pg_data